{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping gpu-dashboard /api/prom",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {"title": "gpu-dashboard repo", "url": "https://github.com/Shad107/gpu-dashboard",
     "type": "link", "icon": "external link", "targetBlank": true}
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "⚡ Energy year-to-date",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_dashboard_kwh_year", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "kwatth", "decimals": 1, "color": {"mode": "fixed", "fixedColor": "blue"}},
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "💸 Cost year-to-date",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_dashboard_cost_year", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "currencyEUR", "decimals": 2, "color": {"mode": "fixed", "fixedColor": "green"}},
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "🪙 LLM tokens year-to-date",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_dashboard_tokens_year_total", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 1, "color": {"mode": "fixed", "fixedColor": "purple"}},
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🚨 Latest alert age",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_dashboard_latest_alert_age_seconds", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "orange", "value": 3600},
              {"color": "green",  "value": 86400}
            ]
          }
        },
        "overrides": []
      },
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GPU power draw (live)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "gpu_power_watts", "legendFormat": "Power (W)", "refId": "A"},
        {"expr": "gpu_power_limit_watts", "legendFormat": "Limit", "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "watt", "min": 0},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Limit"},
           "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 5]}}]}
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "GPU temperature + fan (live)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "gpu_temp_celsius", "legendFormat": "Temp (°C)", "refId": "A"},
        {"expr": "gpu_fan_percent",  "legendFormat": "Fan (%)",   "refId": "B"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "min": 0, "max": 100}
      }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Today's energy",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_dashboard_kwh_today", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "kwatth", "decimals": 2}
      }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "OcuLink drops since boot",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_oculink_drops_total", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 1},
              {"color": "red",    "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "GPU alive ?",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "gpu_alive", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"},
                                          "1": {"text": "UP",   "color": "green"}}}
          ]
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["gpu", "nvidia", "llm", "gpu-dashboard"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {"refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]},
  "timezone": "",
  "title": "gpu-dashboard — Yearly overview",
  "uid": "gpu-dashboard-yearly",
  "version": 1
}
